{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pmk-reviews-backend",
  "main": "worker.mjs",
  "workers_dev": true,
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "browser": {
    "binding": "BROWSER"
  },
  "triggers": {
    "crons": ["15 2 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
